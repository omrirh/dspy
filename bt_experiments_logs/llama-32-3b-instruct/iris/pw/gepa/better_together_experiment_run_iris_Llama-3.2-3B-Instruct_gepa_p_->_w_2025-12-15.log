def predict_iris_species(petal_length, petal_width, sepal_length, sepal_width):
    # Based on the provided petal and sepal dimensions, the flower appears to be more closely related to the virginica species due to its larger petal and sepal dimensions
    # However, the petal length and width do not strictly fall within the optimal range for the virginica species
    # A closer examination reveals that the sepal width is within the optimal range for the virginica species
    # Based on this assessment, the most likely species classification is the virginica species
    if petal_length >= 4 and petal_length <= 6 and petal_width >= 2 and petal_width <= 3.5 and sepal_length >= 5.5 and sepal_length <= 7 and sepal_width >= 2.7 and sepal_width <= 3.5:
        return "virginica"
    elif petal_length >= 1 and petal_length <= 4 and petal_width >= 0.5 and petal_width <= 2 and sepal_length >= 3 and sepal_length <= 5 and sepal_width >= 1.5 and sepal_width <= 4:
        return "setosa"
    elif petal_length >= 4.3 and petal_length <= 5.5 and petal_width >= 1.3 and petal_width <= 1.7 and sepal_length >= 5.1 and sepal_length <= 6.3 and sepal_width >= 2.1 and sepal_width <= 2.5:
        return "versicolor"
    else:
        return "unknown"
