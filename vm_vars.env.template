# Copy to vm_vars.env and fill in values before running any experiment scripts.
# vm_vars.env is gitignored — never commit credentials.

# HuggingFace token (needed for gated model downloads)
HF_TOKEN=hf_YOUR_TOKEN_HERE

# OpenAI-compatible API key for reflection LM (e.g. gpt-4o-mini)
# Leave empty to use the local task model for reflection (self-improving mode)
OPENAI_API_KEY=

# SGLang server port (default 30000)
SGLANG_PORT=30000
